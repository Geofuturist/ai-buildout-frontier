# .env.example — copy to .env and fill in your values
# NEVER commit .env to git.

# Option A: single connection string (recommended for Supabase)
# Find this in Supabase → Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Option B: individual variables (used if DATABASE_URL is not set)
SUPABASE_DB_HOST=db.[YOUR-PROJECT-REF].supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=[YOUR-PASSWORD]

# Frontend (Next.js) — these go to Vercel environment variables too
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-ANON-KEY]
